generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth ──────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles Profile[]
}

// ─── Profiles ──────────────────────────────────────────────────────────────

model Profile {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes        Income[]
  expenses       Expense[]
  investments    Investment[]
  debts          Debt[]
  tasks          Task[]
  notes          Note[]
  habits         Habit[]
  habitLogs      HabitLog[]
  goals          Goal[]
  goalMilestones GoalMilestone[]
}

// ─── Finance ───────────────────────────────────────────────────────────────

model Income {
  id         Int      @id @default(autoincrement())
  profileId  Int
  source     String
  amount     Float
  currency   String   @default("USD")
  frequency  String   // monthly, yearly, one-time
  receivedAt DateTime @default(now())
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int      @id @default(autoincrement())
  profileId   Int
  category    String
  description String
  amount      Float
  currency    String   @default("USD")
  spentAt     DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Investment {
  id           Int      @id @default(autoincrement())
  profileId    Int
  name         String
  type         String   // stocks, crypto, real-estate, bonds, other
  currentValue Float
  costBasis    Float
  currency     String   @default("USD")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Debt {
  id             Int       @id @default(autoincrement())
  profileId      Int
  name           String
  type           String    // credit-card, loan, mortgage, other
  principal      Float
  interestRate   Float
  minimumPayment Float?
  dueDate        DateTime?
  currency       String    @default("USD")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ─── Tasks ─────────────────────────────────────────────────────────────────

model Task {
  id          Int       @id @default(autoincrement())
  profileId   Int
  title       String
  description String?
  status      String    @default("todo")    // todo, in-progress, done
  priority    String    @default("medium")  // low, medium, high
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ─── Notes ─────────────────────────────────────────────────────────────────

model Note {
  id        Int      @id @default(autoincrement())
  profileId Int
  title     String
  content   String
  tags      String   @default("[]")  // JSON array stored as string
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ─── Habits ────────────────────────────────────────────────────────────────

model Habit {
  id          Int      @id @default(autoincrement())
  profileId   Int
  name        String
  description String?
  frequency   String   @default("daily")   // daily, weekly
  targetDays  String   @default("[]")      // JSON array: [0,1,2,3,4,5,6]
  color       String   @default("#6366f1")
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  logs    HabitLog[]
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  profileId Int
  habitId   Int
  date      DateTime // stored as start-of-day UTC
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  habit   Habit   @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

// ─── Goals ─────────────────────────────────────────────────────────────────

model Goal {
  id          Int       @id @default(autoincrement())
  profileId   Int
  title       String
  description String?
  category    String    @default("personal")  // personal, career, health, finance, learning
  status      String    @default("active")    // active, completed, paused, abandoned
  targetDate  DateTime?
  progress    Int       @default(0)           // 0-100
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile    Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]
}

model GoalMilestone {
  id          Int       @id @default(autoincrement())
  profileId   Int
  goalId      Int
  title       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
}
